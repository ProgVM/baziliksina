# =====================================================================
# 1. TELEGRAM API CONFIGURATION
# =====================================================================
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_SESSION_NAME=baziliksina
OWNER_ID=2113692455

# =====================================================================
# 2. SQLITE ENGINE SETTINGS
# =====================================================================
DB_NAME=bot_context.db
SQLITE_JOURNAL_MODE=WAL

# =====================================================================
# 3. GOOGLE GEMINI CONFIGURATION
# =====================================================================
# Comma-separated list of Gemini API keys for key-rotation
GEMINI_API_KEYS=AIzaSyD_key1,AIzaSyD_key2,AIzaSyD_key3
# Comma-separated list of Gemini models for model-rotation
GEMINI_MODELS=gemini-3.5-flash,gemini-3.1-flash-lite,gemini-3-flash-preview
THINKING_LEVEL=high
TEMPERATURE=0.7
TOP_P=0.95
STOP_SEQUENCES=stop1,stop2
OUTPUT_LENGTH=65536
INPUT_TOKEN_LIMIT=1000000

# =====================================================================
# 4. POLLINATIONS AI CONFIGURATION
# =====================================================================
# Comma-separated list of Pollinations API keys (pk_ or sk_)
POLLINATIONS_KEYS=sk_key1,pk_key2
DEFAULT_IMAGE_MODEL=flux
DEFAULT_IMAGE_WIDTH=1024
DEFAULT_IMAGE_HEIGHT=1024
MEDIA_RESOLUTION=high
ASPECT_RATIO=auto
GENERATE_IMAGE_TIMEOUT=180.0

DEFAULT_AUDIO_VOICE=nova
DEFAULT_AUDIO_MODEL=qwen-tts-instruct
GENERATE_AUDIO_TIMEOUT=120.0

DEFAULT_VIDEO_MODEL=wan
DEFAULT_VIDEO_DURATION=5
DEFAULT_VIDEO_ASPECT_RATIO=1:1
GENERATE_VIDEO_TIMEOUT=180.0

DEFAULT_PUBLIC_UPLOAD_PROVIDER=auto
PUBLIC_UPLOAD_TIMEOUT=60.0

# =====================================================================
# 5. TOR AND NETWORK PROXIES CONFIGURATION
# =====================================================================
# Proxy configuration used for all outbound HTTP/HTTPS requests
ALL_PROXY=socks5://127.0.0.1:9050

# Local Tor configurations
TOR_HOST=127.0.0.1
TOR_SOCKS_PORT=9050
TOR_CONTROL_PORT=9051
TOR_PASSWORD=your_tor_control_password
TOR_ROTATION_TIMEOUT=15.0

POLLINATIONS_MAX_ATTEMPTS=8
TOR_MAX_CONSECUTIVE_FAILURES=2

# =====================================================================
# 6. LIMITS, TIMEOUTS, AND INTERVALS
# =====================================================================
# Delay before triggering AI response to group consecutive messages
DEBOUNCE_DELAY=7.0
# Max size of downloaded files in bytes (default 15 MB)
MAX_FILE_SIZE=15728640
# Cache expiry for avatars and profile pictures in seconds (default 24h)
AVATAR_CACHE_TIME=86400
# Max size of deduplication message ID cache
DUPLICATE_CACHE_SIZE=1000
# Max messages loaded from SQLite to active context
MESSAGES_LIMIT=150
# Context window allocation parameters (ratio and minimum messages for active chat)
CONTEXT_LOCAL_RATIO=0.4
CONTEXT_LOCAL_MIN_LIMIT=15
# Max messages loaded from SQLite for summarization (default 500)
SUMMARIZATION_MESSAGES_LIMIT=500
# Messages kept in active history after summarization
SUMMARIZATION_KEEP_LIMIT=15
# Max turns of multi-turn generation loop per query
MAX_TURNS=1000
# Max simultaneously loaded media files in history context
MEDIA_LIMIT=15
# Interval for background updates of profiles and chats (default 1 hour)
PROFILE_UPDATE_INTERVAL=3600

# Cache directories configuration
EMOJI_CACHE_DIR_NAME=emoji_cache
AVATAR_CACHE_DIR_NAME=avatar_cache
GIFT_CACHE_DIR_NAME=gift_cache
TEMP_MEDIA_DIR_NAME=temp_media

# Local asset filenames
BOT_AVATAR_NAME=bot_avatar.jpg
DEFAULT_IMAGE_NAME=generated_image.png
DEFAULT_AUDIO_NAME=generated_audio.mp3
DEFAULT_VIDEO_NAME=generated_video.mp4

# Core intervals and timeouts
GEMINI_TIMEOUT=300.0
TYPING_INTERVAL=10.0
TIMEOUT_SLEEP=2.0
RATE_LIMIT_SLEEP=5.0
API_ERROR_SLEEP=2.0
BOT_RESPONSE_TIMEOUT=6.0
DEFAULT_RESULT_INDEX=0
BUTTON_CLICK_TIMEOUT=15.0
DOWNLOAD_MEDIA_TIMEOUT=120.0
TELEGRAM_ACTION_TIMEOUT=60.0
CONVERSION_TIMEOUT=30.0
TIMERS_LOOP_INTERVAL=1.0
KEEP_ALIVE_INTERVAL=120
CONNECTION_MONITOR_INTERVAL=10

# API-Key recovery times in seconds
GEMINI_FREE_RECOVERY_TIME=18000
GEMINI_PRO_RECOVERY_TIME=86400
POLLINATIONS_KEY_RECOVERY_TIME=3600
KEY_INFO_TIMEOUT=10.0
GOOGLE_UPLOAD_TIMEOUT=120.0

# Database and file configuration
BOOTSTRAP_DATABASE=false
CHARACTER_FILE=character.txt
FFMPEG_PATH=ffmpeg

# Historical catch-up limits
DIALOGS_LIMIT=50
BOOTSTRAP_MESSAGES_LIMIT=20
MISSED_MESSAGES_LIMIT=50

# Global browser user agent masking
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# =====================================================================
# 7. SAFETY FILTERS CONFIGURATION
# Categories: BLOCK_NONE, BLOCK_LOW_AND_ABOVE, BLOCK_MEDIUM_AND_ABOVE, BLOCK_ONLY_HIGH
# =====================================================================
SAFETY_HATE_SPEECH=BLOCK_NONE
SAFETY_HARASSMENT=BLOCK_NONE
SAFETY_SEXUALLY_EXPLICIT=BLOCK_NONE
SAFETY_DANGEROUS_CONTENT=BLOCK_NONE

# =====================================================================
# 8. SANDBOX AND SCRAPER LIMITS
# =====================================================================
SQL_SELECT_LIMIT=100
SQL_STDOUT_CHAR_LIMIT=3500
TELEGRAM_ACTION_CHAR_LIMIT=5000
TELEGRAM_ACTION_CONFIRM_LIMIT=500
VM_STDOUT_NOTICE_LIMIT=1500
SANDBOX_BLOCKED_FILES=bot.py,config.py,db_manager.py,key_manager.py,gemini_manager.py,.env,tools.py,sandbox.py,utils.py,downloader.py,registry.py
SANDBOX_COMMAND_CHAR_LIMIT=3000
WEB_SEARCH_RESULTS_LIMIT=5
SCRAPE_CHAR_LIMIT=4000
WEB_SEARCH_TIMEOUT=10.0
WEB_MEDIA_SEARCH_TIMEOUT=10.0
SCRAPE_TIMEOUT=10.0
